# Copy these values into Vercel > Project Settings > Environment Variables.
# Scope: Production. Use a separate database URL for Preview if needed.
# Prisma and the runtime use DATABASE_URL directly in this repo.
# POSTGRES_URL* variables are optional helpers only unless you intentionally map one into DATABASE_URL.

# Required runtime database variables
PRISMA_DB_PROVIDER=postgresql
# Use your managed PostgreSQL pooler as the runtime DATABASE_URL for this project.
# URL-encode special password characters before pasting into DATABASE_URL.
# Example: @ becomes %40, [ becomes %5B, ] becomes %5D.
# Runtime pooler URL:
DATABASE_URL=postgresql://POOLER_USER:POOLER_PASSWORD@POOLER_HOST:6543/postgres?sslmode=require&pgbouncer=true
# Admin-only direct URL, not the default runtime value:
# postgresql://DIRECT_USER:DIRECT_PASSWORD@DIRECT_DB_HOST:5432/postgres

# Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-production-secret
ADMIN_EMAIL=admin@resurgence.local
ADMIN_PASSWORD_HASH=

# Site
FORCE_HTTPS=true
NEXT_PUBLIC_SITE_URL=https://resurgence-dx.biz
NEXT_PUBLIC_SITE_NAME=Resurgence Powered by DesignXpress
COMPANY_NAME=DesignXpress Merchandising OPC
UPLOAD_STORAGE=r2
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=resurgence-merch
# Optional. Use a custom R2 domain or public r2.dev URL. If blank, the app proxies images through /api/uploads/r2.
R2_PUBLIC_BASE_URL=

# Cloudflare Stream video delivery for creator uploads
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_STREAM_TOKEN=replace-with-cloudflare-stream-api-token
# Use the customer code from Stream. The app will normalize values with or without the customer- prefix.
CLOUDFLARE_STREAM_CUSTOMER_CODE=
CLOUDFLARE_STREAM_ALLOWED_ORIGINS=https://www.resurgence-dx.biz,https://resurgence-dx.biz
CLOUDFLARE_STREAM_MAX_DURATION_SECONDS=180
# Keep this false until tokenized signed playback is implemented in the feed.
CLOUDFLARE_REQUIRE_SIGNED_URLS=false

# Public contact details
NEXT_PUBLIC_CONTACT_NAME=Jake Anilao
NEXT_PUBLIC_CONTACT_ROLE=Sponsorship / Partnerships
NEXT_PUBLIC_CONTACT_EMAIL=partnerships@resurgence-dx.biz
NEXT_PUBLIC_CONTACT_PHONE=+639387841636
NEXT_PUBLIC_SUPPORT_EMAIL=support@resurgence-dx.biz
NEXT_PUBLIC_SUPPORT_PHONE=+639957558147
NEXT_PUBLIC_BUSINESS_HOURS=Monday to Saturday, 9:00 AM to 6:00 PM, Asia/Manila
NEXT_PUBLIC_LOCATION=Philippines
NEXT_PUBLIC_CURRENCY=PHP
NEXT_PUBLIC_PAYMENT_METHODS=GCash, Maya, Bank Transfer, Credit/Debit Card, Cash
NEXT_PUBLIC_SHIPPING_AREA=Philippines nationwide
NEXT_PUBLIC_CONTACT_ADDRESS=Philippines

# Manual shop payment instructions
GCASH_NUMBER=replace-with-gcash-number
MAYA_NUMBER=
BANK_ACCOUNT_NAME=replace-with-bank-account-name
BANK_ACCOUNT_NUMBER=replace-with-bank-account-number
BANK_NAME=replace-with-bank-name

# Optional AI support and workflow integrations
OPENAI_API_KEY=
OPENAI_WORKFLOW_ID=
OPENAI_WORKFLOW_VERSION=1
OPENAI_WEBHOOK_SECRET=
OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# Public registration
# Required for Google sign-in in Vercel. Keep both values the same.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
OTP_DELIVERY_MODE=demo
SMS_WEBHOOK_URL=
SMS_WEBHOOK_SECRET=

EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_SECRET=

# Runtime
NEXT_TELEMETRY_DISABLED=1
PRISMA_HIDE_UPDATE_MESSAGE=1

# Optional platform helper variables not read directly by the current codebase:
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PASSWORD=

# Unused in the current codebase:
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# Secret hygiene:
# Keep tracked examples placeholder-only. Do not commit a real project ref,
# pooler hostname, direct DB hostname, password fragment, or live API secret.
