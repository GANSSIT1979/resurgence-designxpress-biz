# RESURGENCE Google Auth - Vercel Environment Variables

# Required for client-side Google button on /login
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_WEB_CLIENT_ID>

# Required for server-side token audience verification in /api/auth/google
GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_WEB_CLIENT_ID>

# Existing required production variables for the app
PRISMA_DB_PROVIDER=postgresql
DATABASE_URL=postgresql://POOLER_USER:POOLER_PASSWORD@POOLER_HOST:6543/postgres?sslmode=require&pgbouncer=true
JWT_SECRET=<GENERATED_RANDOM_SECRET>
NEXT_PUBLIC_SITE_URL=https://www.resurgence-dx.biz
FORCE_HTTPS=true

# Optional OTP setup
OTP_DELIVERY_MODE=demo
SMS_WEBHOOK_URL=
SMS_WEBHOOK_SECRET=

# Vercel deployment webhook secret. Do not commit the real value.
VERCEL_WEBHOOK_SECRET=<GENERATED_VERCEL_WEBHOOK_SECRET>
