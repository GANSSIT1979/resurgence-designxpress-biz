  @@id([postId, hashtagId])
  @@index([hashtagId])
}
model PostLike {
  id        String      @id @default(cuid())
  postId    String
  userId    String
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation("PostLikeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([postId, userId])
  @@index([userId, createdAt])
}
model PostComment {
  id               String                       @id @default(cuid())
  postId           String
  userId           String?
  parentCommentId  String?
  post             ContentPost                  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user             User?                        @relation("PostCommentAuthor", fields: [userId], references: [id], onDelete: SetNull)
  parentComment    PostComment?                 @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          PostComment[]                @relation("CommentReplies")
  body             String
  bodyPlain        String?
  status           ContentPostCommentStatus     @default(ACTIVE)
  visibility       ContentPostCommentVisibility @default(PUBLIC)
  isHidden         Boolean                      @default(false)
  isPinned         Boolean                      @default(false)
  isEdited         Boolean                      @default(false)
  likeCount        Int                          @default(0)
  replyCount       Int                          @default(0)
  sortOrder        Int                          @default(0)
  moderationReason String?
  moderationNotes  String?
