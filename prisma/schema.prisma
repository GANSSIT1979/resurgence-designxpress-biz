  postCount           Int            @default(0)
  publishedPostCount  Int            @default(0)
  viewCount           Int            @default(0)
  uniqueViewCount     Int            @default(0)
  watchTimeSeconds    Int            @default(0)
  completedViewCount  Int            @default(0)
  avgWatchTimeSeconds Float          @default(0)
  completionRate      Float          @default(0)
  shareCount          Int            @default(0)
  likeCount           Int            @default(0)
  saveCount           Int            @default(0)
  commentCount        Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  creatorProfile      CreatorProfile @relation("CreatorAnalyticsCreatorProfile", fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, date])
  @@index([date])
  @@index([creatorProfileId, date])
  @@index([creatorProfileId, viewCount])
}
model ContentPostViewSession {
