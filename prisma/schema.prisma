generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
enum InquiryStatus {
  NEW
  UNDER_REVIEW
  CONTACTED
  QUALIFIED
  PENDING_RESPONSE
  CLOSED
  ARCHIVED
}
enum SponsorSubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  NEEDS_REVISION
  APPROVED
  REJECTED
  CONVERTED_TO_ACTIVE_SPONSOR
}
enum UserRole {
  SYSTEM_ADMIN
  CASHIER
  MEMBER
  SPONSOR
  STAFF
  PARTNER
  CREATOR
  COACH
  REFEREE
}
enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  GCASH
  MAYA
  CHECK
  OTHER
}
enum CashierTransactionKind {
  COLLECTION
  REFUND
  ADJUSTMENT
}
enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  NEEDS_REVISION
  COMPLETED
}
enum PartnerCampaignStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}
enum PartnerReferralStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}
enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}
enum StaffTaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
enum StaffTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
}
enum AnnouncementLevel {
  INFO
  SUCCESS
  WARNING
  URGENT
}
enum EmailAutomationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}
enum ContentPostStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  HIDDEN
  ARCHIVED
  DELETED
}
enum ContentPostVisibility {
  PUBLIC
  MEMBERS_ONLY
  PRIVATE
}
enum ContentPostMediaType {
  IMAGE
  VIDEO
  YOUTUBE
  VIMEO
  EXTERNAL
}
enum ContentPostCommentStatus {
  ACTIVE
  HIDDEN
  REMOVED
  PENDING_REVIEW
  SPAM
}
enum ContentPostCommentVisibility {
  PUBLIC
  FOLLOWERS_ONLY
  PRIVATE
}
enum ContentViewSource {
  FEED
  PROFILE
  PRODUCT
  DIRECT_LINK
  EMBED
  UNKNOWN
}
enum SponsoredPlacementStatus {
  DRAFT
  PENDING
  APPROVED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  REJECTED
}

enum CreatorPayoutRequestStatus {
  REQUESTED
  UNDER_REVIEW
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}
model CreatorPayoutRequest {
  id                 String                     @id @default(cuid())
  creatorId          String?
  creatorProfileId   String?
  requestedAmount    Decimal                    @default(0) @db.Decimal(12, 2)
  amountCents        Int?
  approvedAmount     Decimal?                   @db.Decimal(12, 2)
  currency           String                     @default("PHP")
  status             CreatorPayoutRequestStatus @default(PENDING)

  provider           String?
  providerAccountId  String?
  payoutAccountId    String?
  providerTransferId String?
  referenceNumber    String?
  notes              String?
  rejectionReason    String?
  metadata           Json?

  requestedAt        DateTime                   @default(now())
  reviewedById       String?
  reviewedAt         DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  processingAt       DateTime?
  paidAt             DateTime?
  failedAt           DateTime?

  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([creatorId])
  @@index([creatorProfileId])
  @@index([status])
  @@index([requestedAt])
  @@index([reviewedById])
  @@index([payoutAccountId])
  @@unique([providerTransferId])
}

enum AffiliateEventType {
  VIEW
  CLICK
  SHARE
  PURCHASE
}
enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  VOIDED
}
model AffiliateLink {
  id               String           @id @default(cuid())
  code             String           @unique
  creatorProfileId String?
  productId        String?
  postId           String?
  destinationUrl   String?
  isActive         Boolean          @default(true)
  metadataJson     Json?
  events           AffiliateEvent[]
  commissions      Commission[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([creatorProfileId])
  @@index([productId])
  @@index([postId])
  @@index([isActive, createdAt])
}
model AffiliateEvent {
  id               String             @id @default(cuid())
  type             AffiliateEventType
  affiliateLinkId  String?
  affiliateLink    AffiliateLink?      @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  affiliateCode    String?
  creatorProfileId String?
  productId        String?
  postId           String?
  userId           String?
  orderId          String?
  source           String?
  sessionKey       String?
  ipHash           String?
  userAgent        String?
  amountCents      Int?
  currency         String              @default("PHP")
  metadataJson     Json?
  createdAt        DateTime            @default(now())

  @@index([type, createdAt])
  @@index([affiliateCode, createdAt])
  @@index([creatorProfileId, createdAt])
  @@index([productId, createdAt])
  @@index([postId, createdAt])
  @@index([orderId])
  @@index([sessionKey, createdAt])
}
model Commission {
  id                String           @id @default(cuid())
  affiliateLinkId   String?
  affiliateLink     AffiliateLink?    @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  affiliateCode     String?
  creatorProfileId  String?
  productId         String?
  postId            String?
  orderId           String
  currency          String           @default("PHP")
  orderAmountCents  Int
  commissionRateBps Int              @default(1000)
  commissionCents   Int
  status            CommissionStatus @default(PENDING)
  approvedAt        DateTime?
  paidAt            DateTime?
  metadataJson      Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([orderId, affiliateCode])
  @@index([creatorProfileId, status, createdAt])
  @@index([affiliateCode, status, createdAt])
  @@index([productId, createdAt])
  @@index([postId, createdAt])
  @@index([status, createdAt])
}
model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  phoneNumber           String?                @unique
  password              String
  displayName           String
  title                 String?
  role                  UserRole
  authProvider          String                 @default("PASSWORD")
  isEmailVerified       Boolean                @default(false)
  isPhoneVerified       Boolean                @default(false)
  referralCode          String?
  profileImageUrl       String?
  termsAcceptedAt       DateTime?
  isActive              Boolean                @default(true)
  lastLoginAt           DateTime?

  sponsorProfile        SponsorProfile?
  staffProfile          StaffProfile?
  partnerProfile        PartnerProfile?
  creatorProfile        CreatorProfile?

  activityLogs ActivityLog[] @relation("ActivityActor")
  savedViews   SavedView[]

  notifications         PlatformNotification[] @relation("NotificationRecipient")
  actorNotifications    PlatformNotification[] @relation("NotificationActor")
  emails                AutomatedEmail[]       @relation("EmailRecipient")

  contentPosts             ContentPost[]            @relation("PostAuthor")
  contentPostAnalyticsDays ContentPostAnalyticsDay[] @relation("ContentPostAnalyticsAuthor")
  postLikes                PostLike[]               @relation("PostLikeUser")
  postComments             PostComment[]            @relation("PostCommentAuthor")
  moderatedPostComments    PostComment[]            @relation("PostCommentModerator")
  postSaves                PostSave[]               @relation("PostSaveUser")
  contentPostViewSessions  ContentPostViewSession[] @relation("ContentPostAnalyticsViewer")
  following                Follow[]                 @relation("CreatorFollowUser")

  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
}
model ActivityLog {
  id               String    @id @default(cuid())
  actorId          String?
  actor            User?     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail       String
  actorDisplayName String?
  actorRole        UserRole?
  action           String
  resource         String
  resourceId       String?
  targetLabel      String?
  metadataJson     String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime  @default(now())

  @@index([actorId, createdAt])
  @@index([actorEmail, createdAt])
  @@index([actorRole, createdAt])
  @@index([resource, createdAt])
  @@index([action, createdAt])
}

model VerificationCode {
  id         String    @id @default(cuid())
  identifier String
  channel    String
  purpose    String
  codeHash   String
  payload    Json?
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier, purpose, createdAt])
  @@index([expiresAt])
}
model UploadAsset {
  id              String   @id @default(cuid())
  scope           String
  filename        String
  contentType     String
  size            Int
  data            Bytes
  uploadedById    String?
  uploadedByEmail String?
  createdAt       DateTime @default(now())

  @@index([scope, createdAt])
  @@index([uploadedByEmail])
}
model Inquiry {
  id                     String        @id @default(cuid())
  name                   String
  organization           String?
  email                  String
  phone                  String?
  inquiryType            String
  message                String
  status                 InquiryStatus @default(NEW)
  internalNotes          String?
  followUpAt             DateTime?
  assignedStaffProfileId String?
  assignedStaffProfile   StaffProfile? @relation(fields: [assignedStaffProfileId], references: [id], onDelete: SetNull)
  staffTasks             StaffTask[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([assignedStaffProfileId, status])
}
model Sponsor {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  tier                String
  logoUrl             String?
  websiteUrl          String?
  shortDescription    String
  packageValue        String
  benefits            String
  sortOrder           Int                  @default(0)
  isActive            Boolean              @default(true)
  sponsorProfiles     SponsorProfile[]
  invoices            Invoice[]
  sponsoredPlacements SponsoredPlacement[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}
model Partner {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  category         String
  logoUrl          String?
  websiteUrl       String?
  shortDescription String
  services         String
  sortOrder        Int              @default(0)
  isActive         Boolean          @default(true)
  partnerProfiles  PartnerProfile[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}
model PageContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  subtitle  String?
  body      String
  ctaLabel  String?
  ctaHref   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
model SponsorProfile {
  id                  String                  @id @default(cuid())
  userId              String                  @unique
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sponsorId           String?
  sponsor             Sponsor?                @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  preferredPackageId  String?
  preferredPackage    SponsorPackageTemplate? @relation(fields: [preferredPackageId], references: [id], onDelete: SetNull)
  companyName         String
  contactName         String
  contactEmail        String
  phone               String?
  websiteUrl          String?
  address             String?
  brandSummary        String?
  assetLink           String?
  submissions         SponsorSubmission[]
  deliverables        SponsorDeliverable[]
  sponsoredPlacements SponsoredPlacement[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([sponsorId])
  @@index([preferredPackageId])
  @@index([companyName])
  @@index([contactEmail])
}
model RevenueRecord {
  id                 String   @id @default(cuid())
  saleDate           DateTime @default(now())
  sourceType         String
  title              String
  referenceNo        String?
  creatorProfileId   String?
  partnerId          String?
  creatorName        String?
  partnerName        String?
  sponsorName        String?
  productCategory    String?
  merchandiseType    String?
  quantity           Int?
  unitPrice          Float?
  grossSales         Float    @default(0)
  costAmount         Float?   @default(0)
  netRevenue         Float?   @default(0)
  sponsorshipPercent Float?   @default(0)
  talentFeeAmount    Float?   @default(0)
  franchiseAmount    Float?   @default(0)
  companyShareAmount Float?   @default(0)
  notes              String?
  attachmentUrl      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([saleDate])
  @@index([sourceType])
  @@index([creatorProfileId])
  @@index([partnerId])
  @@index([creatorName])
  @@index([partnerName])
}

model SavedView {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope       String
  name        String
  search      String?
  status      String?
  filtersJson String?
  sortJson    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, scope])
  @@unique([userId, scope, name])
}

model SponsorSubmission {
  id                String                  @id @default(cuid())
  sponsorProfileId  String?
  sponsorProfile    SponsorProfile?         @relation(fields: [sponsorProfileId], references: [id], onDelete: SetNull)
  companyName       String
  contactName       String
  email             String
  phone             String?
  websiteUrl        String?
  category          String
  interestedPackage String
  budgetRange       String
  timeline          String?
  message           String
  status            SponsorSubmissionStatus @default(SUBMITTED)
  internalNotes     String?
  staffTasks        StaffTask[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([companyName])
  @@index([sponsorProfileId, createdAt])
}
model SponsorPackageTemplate {
  id              String           @id @default(cuid())
  name            String           @unique
  tier            String
  rangeLabel      String
  summary         String
  benefits        String
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  sponsorProfiles SponsorProfile[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}
model StaffProfile {
  id                String              @id @default(cuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        String
  bio               String?
  assignedInquiries Inquiry[]
  tasks             StaffTask[]
  scheduleItems     StaffScheduleItem[]
  announcements     StaffAnnouncement[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([department])
}
model StaffTask {
  id                  String             @id @default(cuid())
  staffProfileId      String
  staffProfile        StaffProfile       @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  priority            StaffTaskPriority  @default(NORMAL)
  status              StaffTaskStatus    @default(TODO)
  dueDate             DateTime?
  completedAt         DateTime?
  inquiryId           String?
  inquiry             Inquiry?           @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  sponsorSubmissionId String?
  sponsorSubmission   SponsorSubmission? @relation(fields: [sponsorSubmissionId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([staffProfileId, status])
  @@index([dueDate])
  @@index([inquiryId])
  @@index([sponsorSubmissionId])
}
model StaffScheduleItem {
  id             String       @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  title          String
  location       String?
  startAt        DateTime
  endAt          DateTime
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([staffProfileId, startAt])
}
model StaffAnnouncement {
  id             String            @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  title          String
  body           String
  level          AnnouncementLevel @default(INFO)
  isPinned       Boolean           @default(false)
  publishAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([staffProfileId, isPinned, publishAt])
}
model PlatformNotification {
  id              String            @id @default(cuid())
  recipientRole   UserRole?
  recipientUserId String?
  recipientUser   User?             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  actorUserId     String?
  actorUser       User?             @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  contentPostId   String?
  contentPost     ContentPost?      @relation(fields: [contentPostId], references: [id], onDelete: SetNull)
  kind            String?
  title           String
  message         String
  level           AnnouncementLevel @default(INFO)
  href            String?
  metadataJson    String?
  isRead          Boolean           @default(false)
  readAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([recipientRole, createdAt])
  @@index([recipientUserId, isRead, createdAt])
  @@index([actorUserId, createdAt])
  @@index([contentPostId, createdAt])
}
model AutomatedEmail {
  id               String                @id @default(cuid())
  recipientRole    UserRole?
  recipientUserId  String?
  recipientUser    User?                 @relation("EmailRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  toEmail          String
  toName           String?
  subject          String
  bodyText         String
  bodyHtml         String?
  eventKey         String
  relatedType      String?
  relatedId        String?
  status           EmailAutomationStatus @default(QUEUED)
  deliveryResponse String?
  errorMessage     String?
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([recipientRole, createdAt])
  @@index([recipientUserId, status, createdAt])
  @@index([toEmail, createdAt])
  @@index([eventKey, createdAt])
}
model PartnerProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnerId         String?
  partner           Partner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  companyName       String
  contactName       String
  contactEmail      String
  phone             String?
  websiteUrl        String?
  address           String?
  companySummary    String?
  assetLink         String?
  preferredServices String?
  campaigns         PartnerCampaign[]
  referrals         PartnerReferral[]
  agreements        PartnerAgreement[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([partnerId])
  @@index([companyName])
  @@index([contactEmail])
}
model PartnerCampaign {
  id                String                @id @default(cuid())
  partnerProfileId  String
  partnerProfile    PartnerProfile        @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  title             String
  campaignType      String
  status            PartnerCampaignStatus @default(PLANNING)
  description       String?
  startDate         DateTime?
  endDate           DateTime?
  contributionValue Int?
  assetLink         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([partnerProfileId, status])
  @@index([startDate, endDate])
}
model PartnerReferral {
  id               String                @id @default(cuid())
  partnerProfileId String
  partnerProfile   PartnerProfile        @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  companyName      String
  contactName      String
  email            String
  phone            String?
  status           PartnerReferralStatus @default(NEW)
  notes            String?
  estimatedValue   Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([partnerProfileId, status])
  @@index([email])
  @@index([companyName])
}
model PartnerAgreement {
  id               String          @id @default(cuid())
  partnerProfileId String
  partnerProfile   PartnerProfile  @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  title            String
  agreementType    String
  status           AgreementStatus @default(DRAFT)
  startDate        DateTime?
  endDate          DateTime?
  documentUrl      String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([partnerProfileId, status])
  @@index([startDate, endDate])
}
enum GalleryMediaType {
  IMAGE
  VIDEO
  YOUTUBE
  VIMEO
}
model CreatorProfile {
  id                 String        @id @default(cuid())
  userId             String?       @unique
  user               User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  name               String        @unique
  slug               String        @unique
  roleLabel          String
  platformFocus      String
  audience           String
  biography          String?
  journeyStory       String?
  contactNumber      String?
  address            String?
  dateOfBirth        DateTime?
  jobDescription     String        @default("")
  position           String?
  height             String?
  facebookPage       String?
  facebookFollowers  String?
  tiktokPage         String?
  tiktokFollowers    String?
  instagramPage      String?
  instagramFollowers String?
  youtubePage        String?
  youtubeFollowers   String?
  trendingVideoUrl   String?
  shortBio           String?
  pointsPerGame      Float?
  assistsPerGame     Float?
  reboundsPerGame    Float?
  imageUrl           String?
  mediaEvents        MediaEvent[]
  contentPosts       ContentPost[]             @relation("CreatorContentPosts")
  analyticsDays      ContentPostAnalyticsDay[] @relation("ContentPostAnalyticsCreatorProfile")
  analyticsRollups   CreatorAnalyticsDay[]     @relation("CreatorAnalyticsCreatorProfile")
  viewSessions       ContentPostViewSession[]  @relation("CreatorAnalyticsViewSessions")
  followers          Follow[]                  @relation("CreatorFollowers")
  sortOrder          Int                       @default(0)
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([userId])
  @@index([isActive, sortOrder])
  @@index([position])
}
model MediaEvent {
  id          String          @id @default(cuid())
  title       String
  description String?
  eventDate   DateTime?
  creatorId   String?
  creator     CreatorProfile? @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  mediaItems  GalleryMedia[]
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([creatorId, eventDate])
  @@index([isActive, sortOrder])
}
model GalleryMedia {
  id           String           @id @default(cuid())
  mediaEventId String
  mediaEvent   MediaEvent       @relation(fields: [mediaEventId], references: [id], onDelete: Cascade)
  mediaType    GalleryMediaType @default(IMAGE)
  url          String
  thumbnailUrl String?
  caption      String?
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([mediaEventId, sortOrder])
}
model ContentPost {
  id                  String                 @id @default(cuid())
  authorUserId        String?
  authorUser          User?                  @relation("PostAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  creatorProfileId    String?
  creatorProfile      CreatorProfile?        @relation("CreatorContentPosts", fields: [creatorProfileId], references: [id], onDelete: SetNull)
  title               String?
  caption             String
  summary             String?
  slug                String?                @unique
  visibility          ContentPostVisibility  @default(PUBLIC)
  status              ContentPostStatus      @default(DRAFT)
  isFeatured          Boolean                @default(false)
  isPinned            Boolean                @default(false)
  moderationReason    String?
  publishedAt         DateTime?
  archivedAt          DateTime?
  likeCount           Int                    @default(0)
  commentCount        Int                    @default(0)
  lastCommentedAt     DateTime?
  saveCount           Int                    @default(0)
  shareCount          Int                    @default(0)
  viewCount           Int                    @default(0)
  uniqueViewCount     Int                    @default(0)
  watchTimeSeconds    Int                    @default(0)
  completedViewCount  Int                    @default(0)
  avgWatchTimeSeconds Float                  @default(0)
  completionRate      Float                  @default(0)
  firstViewedAt       DateTime?
  lastViewedAt        DateTime?
  lastAnalyticsRollupAt DateTime?
  metadataJson        Json?
  analyticsDays       ContentPostAnalyticsDay[]
  viewSessions        ContentPostViewSession[]
  mediaAssets         MediaAsset[]
  hashtags            PostHashtag[]
  likes               PostLike[]
  comments            PostComment[]
  saves               PostSave[]
  productTags         PostProductTag[]
  sponsoredPlacements SponsoredPlacement[]
  notifications       PlatformNotification[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([status, visibility, publishedAt])
  @@index([creatorProfileId, status, publishedAt])
  @@index([authorUserId, createdAt])
  @@index([isFeatured, publishedAt])
  @@index([commentCount])
  @@index([lastCommentedAt])
  @@index([lastViewedAt])
  @@index([publishedAt])
  @@index([viewCount])
  @@index([uniqueViewCount])
  @@index([completedViewCount])
}
model ContentPostAnalyticsDay {
  id                  String         @id @default(cuid())
  contentPostId       String
  creatorProfileId    String?
  authorUserId        String?
  date                DateTime
  viewCount           Int            @default(0)
  uniqueViewCount     Int            @default(0)
  watchTimeSeconds    Int            @default(0)
  completedViewCount  Int            @default(0)
  avgWatchTimeSeconds Float          @default(0)
  completionRate      Float          @default(0)
  shareCount          Int            @default(0)
  likeCount           Int            @default(0)
  saveCount           Int            @default(0)
  commentCount        Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  contentPost         ContentPost     @relation(fields: [contentPostId], references: [id], onDelete: Cascade)
  creatorProfile      CreatorProfile? @relation("ContentPostAnalyticsCreatorProfile", fields: [creatorProfileId], references: [id], onDelete: SetNull)
  authorUser          User?           @relation("ContentPostAnalyticsAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([contentPostId, date])
  @@index([creatorProfileId, date])
  @@index([authorUserId, date])
  @@index([date])
  @@index([creatorProfileId, date, viewCount])
}
model CreatorAnalyticsDay {
  id                  String         @id @default(cuid())
