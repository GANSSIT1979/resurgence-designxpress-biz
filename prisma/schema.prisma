generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum InquiryStatus {
  NEW
  UNDER_REVIEW
  CONTACTED
  QUALIFIED
  PENDING_RESPONSE
  CLOSED
  ARCHIVED
}

enum SponsorSubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  NEEDS_REVISION
  APPROVED
  REJECTED
  CONVERTED_TO_ACTIVE_SPONSOR
}

enum UserRole {
  SYSTEM_ADMIN
  CASHIER
  SPONSOR
  STAFF
  PARTNER
  CREATOR
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  GCASH
  MAYA
  CHECK
  OTHER
}

enum CashierTransactionKind {
  COLLECTION
  REFUND
  ADJUSTMENT
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  NEEDS_REVISION
  COMPLETED
}

enum PartnerCampaignStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PartnerReferralStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum StaffTaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum StaffTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum AnnouncementLevel {
  INFO
  SUCCESS
  WARNING
  URGENT
}

enum EmailAutomationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  displayName    String
  title          String?
  role           UserRole
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  sponsorProfile SponsorProfile?
  staffProfile   StaffProfile?
  partnerProfile PartnerProfile?
  creatorProfile CreatorProfile?
  notifications  PlatformNotification[] @relation("NotificationRecipient")
  emails         AutomatedEmail[]       @relation("EmailRecipient")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Inquiry {
  id                     String        @id @default(cuid())
  name                   String
  organization           String?
  email                  String
  phone                  String?
  inquiryType            String
  message                String
  status                 InquiryStatus @default(NEW)
  internalNotes          String?
  followUpAt             DateTime?
  assignedStaffProfileId String?
  assignedStaffProfile   StaffProfile? @relation(fields: [assignedStaffProfileId], references: [id], onDelete: SetNull)
  staffTasks             StaffTask[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([assignedStaffProfileId, status])
}

model Sponsor {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  tier             String
  logoUrl          String?
  websiteUrl       String?
  shortDescription String
  packageValue     String
  benefits         String
  sortOrder        Int              @default(0)
  isActive         Boolean          @default(true)
  sponsorProfiles  SponsorProfile[]
  invoices         Invoice[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Partner {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  category         String
  logoUrl          String?
  websiteUrl       String?
  shortDescription String
  services         String
  sortOrder        Int              @default(0)
  isActive         Boolean          @default(true)
  partnerProfiles  PartnerProfile[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  subtitle  String?
  body      String
  ctaLabel  String?
  ctaHref   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model SponsorProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sponsorId          String?
  sponsor            Sponsor?                @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  preferredPackageId String?
  preferredPackage   SponsorPackageTemplate? @relation(fields: [preferredPackageId], references: [id], onDelete: SetNull)
  companyName        String
  contactName        String
  contactEmail       String
  phone              String?
  websiteUrl         String?
  address            String?
  brandSummary       String?
  assetLink          String?
  submissions        SponsorSubmission[]
  deliverables       SponsorDeliverable[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([sponsorId])
  @@index([preferredPackageId])
  @@index([companyName])
  @@index([contactEmail])
}

model SponsorSubmission {
  id                String                  @id @default(cuid())
  sponsorProfileId  String?
  sponsorProfile    SponsorProfile?         @relation(fields: [sponsorProfileId], references: [id], onDelete: SetNull)
  companyName       String
  contactName       String
  email             String
  phone             String?
  websiteUrl        String?
  category          String
  interestedPackage String
  budgetRange       String
  timeline          String?
  message           String
  status            SponsorSubmissionStatus @default(SUBMITTED)
  internalNotes     String?
  staffTasks        StaffTask[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([companyName])
  @@index([sponsorProfileId, createdAt])
}

model SponsorPackageTemplate {
  id              String           @id @default(cuid())
  name            String           @unique
  tier            String
  rangeLabel      String
  summary         String
  benefits        String
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  sponsorProfiles SponsorProfile[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model StaffProfile {
  id                String              @id @default(cuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        String
  bio               String?
  assignedInquiries Inquiry[]
  tasks             StaffTask[]
  scheduleItems     StaffScheduleItem[]
  announcements     StaffAnnouncement[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([department])
}

model StaffTask {
  id                  String            @id @default(cuid())
  staffProfileId      String
  staffProfile        StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  priority            StaffTaskPriority @default(NORMAL)
  status              StaffTaskStatus   @default(TODO)
  dueDate             DateTime?
  completedAt         DateTime?
  inquiryId           String?
  inquiry             Inquiry?          @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  sponsorSubmissionId String?
  sponsorSubmission   SponsorSubmission? @relation(fields: [sponsorSubmissionId], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([staffProfileId, status])
  @@index([dueDate])
  @@index([inquiryId])
  @@index([sponsorSubmissionId])
}

model StaffScheduleItem {
  id             String       @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  title          String
  location       String?
  startAt        DateTime
  endAt          DateTime
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([staffProfileId, startAt])
}

model StaffAnnouncement {
  id             String            @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  title          String
  body           String
  level          AnnouncementLevel @default(INFO)
  isPinned       Boolean           @default(false)
  publishAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([staffProfileId, isPinned, publishAt])
}

model PlatformNotification {
  id              String            @id @default(cuid())
  recipientRole   UserRole?
  recipientUserId String?
  recipientUser   User?             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  title           String
  message         String
  level           AnnouncementLevel @default(INFO)
  href            String?
  metadataJson    String?
  isRead          Boolean           @default(false)
  readAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([recipientRole, createdAt])
  @@index([recipientUserId, isRead, createdAt])
}

model AutomatedEmail {
  id               String                @id @default(cuid())
  recipientRole    UserRole?
  recipientUserId  String?
  recipientUser    User?                 @relation("EmailRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  toEmail          String
  toName           String?
  subject          String
  bodyText         String
  bodyHtml         String?
  eventKey         String
  relatedType      String?
  relatedId        String?
  status           EmailAutomationStatus @default(QUEUED)
  deliveryResponse String?
  errorMessage     String?
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([recipientRole, createdAt])
  @@index([recipientUserId, status, createdAt])
  @@index([toEmail, createdAt])
  @@index([eventKey, createdAt])
}

model PartnerProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnerId         String?
  partner           Partner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  companyName       String
  contactName       String
  contactEmail      String
  phone             String?
  websiteUrl        String?
  address           String?
  companySummary    String?
  assetLink         String?
  preferredServices String?
  campaigns         PartnerCampaign[]
  referrals         PartnerReferral[]
  agreements        PartnerAgreement[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([partnerId])
  @@index([companyName])
  @@index([contactEmail])
}

model PartnerCampaign {
  id                String                @id @default(cuid())
  partnerProfileId  String
  partnerProfile    PartnerProfile        @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  title             String
  campaignType      String
  status            PartnerCampaignStatus @default(PLANNING)
  description       String?
  startDate         DateTime?
  endDate           DateTime?
  contributionValue Int?
  assetLink         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([partnerProfileId, status])
  @@index([startDate, endDate])
}

model PartnerReferral {
  id               String                @id @default(cuid())
  partnerProfileId String
  partnerProfile   PartnerProfile        @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  companyName      String
  contactName      String
  email            String
  phone            String?
  status           PartnerReferralStatus @default(NEW)
  notes            String?
  estimatedValue   Int?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([partnerProfileId, status])
  @@index([email])
  @@index([companyName])
}

model PartnerAgreement {
  id               String          @id @default(cuid())
  partnerProfileId String
  partnerProfile   PartnerProfile  @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  title            String
  agreementType    String
  status           AgreementStatus @default(DRAFT)
  startDate        DateTime?
  endDate          DateTime?
  documentUrl      String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([partnerProfileId, status])
  @@index([startDate, endDate])
}

enum GalleryMediaType {
  IMAGE
  VIDEO
  YOUTUBE
  VIMEO
}

model CreatorProfile {
  id               String       @id @default(cuid())
  userId           String?      @unique
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String       @unique
  slug             String       @unique
  roleLabel        String
  platformFocus    String
  audience         String
  biography        String?
  journeyStory     String?
  contactNumber    String?
  address          String?
  dateOfBirth      DateTime?
  jobDescription   String       @default("")
  position         String?
  height           String?
  facebookPage     String?
  facebookFollowers String?
  tiktokPage       String?
  tiktokFollowers  String?
  instagramPage    String?
  instagramFollowers String?
  youtubePage      String?
  youtubeFollowers String?
  trendingVideoUrl String?
  shortBio         String?
  pointsPerGame    Float?
  assistsPerGame   Float?
  reboundsPerGame  Float?
  imageUrl         String?
  mediaEvents      MediaEvent[]
  sortOrder        Int          @default(0)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([userId])
  @@index([isActive, sortOrder])
  @@index([position])
}


model MediaEvent {
  id          String          @id @default(cuid())
  title       String
  description String?
  eventDate   DateTime?
  creatorId   String?
  creator     CreatorProfile? @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  mediaItems  GalleryMedia[]
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([creatorId, eventDate])
  @@index([isActive, sortOrder])
}

model GalleryMedia {
  id          String          @id @default(cuid())
  mediaEventId String
  mediaEvent   MediaEvent      @relation(fields: [mediaEventId], references: [id], onDelete: Cascade)
  mediaType   GalleryMediaType @default(IMAGE)
  url         String
  thumbnailUrl String?
  caption     String?
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([mediaEventId, sortOrder])
}

model SponsorInventoryCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  examples    String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SponsorDeliverable {
  id               String            @id @default(cuid())
  sponsorProfileId String
  sponsorProfile   SponsorProfile    @relation(fields: [sponsorProfileId], references: [id], onDelete: Cascade)
  title            String
  category         String
  status           DeliverableStatus @default(PENDING)
  dueDate          DateTime?
  assetLink        String?
  sponsorNotes     String?
  adminNotes       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([sponsorProfileId, status])
  @@index([category])
}

model Invoice {
  id            String               @id @default(cuid())
  invoiceNumber String               @unique
  companyName   String
  contactName   String?
  email         String?
  tier          String?
  description   String
  amount        Int
  balanceAmount Int
  status        InvoiceStatus        @default(ISSUED)
  issueDate     DateTime             @default(now())
  dueDate       DateTime?
  notes         String?
  sponsorId     String?
  sponsor       Sponsor?             @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  transactions  CashierTransaction[]
  receipts      Receipt[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status, dueDate])
  @@index([companyName])
  @@index([sponsorId, issueDate])
}

model CashierTransaction {
  id                String                 @id @default(cuid())
  transactionNumber String                 @unique
  invoiceId         String?
  invoice           Invoice?               @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  companyName       String
  description       String
  amount            Int
  kind              CashierTransactionKind @default(COLLECTION)
  paymentMethod     PaymentMethod          @default(BANK_TRANSFER)
  referenceNumber   String?
  transactionDate   DateTime               @default(now())
  notes             String?
  receipts          Receipt[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([invoiceId, transactionDate])
  @@index([kind, transactionDate])
  @@index([companyName])
}

model Receipt {
  id            String              @id @default(cuid())
  receiptNumber String              @unique
  invoiceId     String?
  invoice       Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  transactionId String?
  transaction   CashierTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  companyName   String
  receivedFrom  String
  amount        Int
  paymentMethod PaymentMethod       @default(BANK_TRANSFER)
  issuedAt      DateTime            @default(now())
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([invoiceId, issuedAt])
  @@index([transactionId])
  @@index([companyName])
}


model ProductService {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  features    String
  priceLabel  String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, sortOrder])
  @@index([isActive, sortOrder])
}


model AdminReport {
  id               String   @id @default(cuid())
  title            String
  reportType       String   @default("SYSTEM_ADMIN")
  summary          String?
  payloadJson      String
  generatedByEmail String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([reportType, createdAt])
}


model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}


enum ShopOrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShopPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShopPaymentMethod {
  COD
  GCASH_MANUAL
  BANK_TRANSFER
}

model ShopCategory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products    ShopProduct[]

  @@index([isActive, sortOrder])
}

model ShopProduct {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  sku              String?         @unique
  description      String
  shortDescription String?
  price            Int
  compareAtPrice   Int?
  stock            Int             @default(0)
  imageUrl         String?
  sortOrder        Int             @default(0)
  isActive         Boolean         @default(true)
  isFeatured       Boolean         @default(false)
  categoryId       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  category         ShopCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems       ShopOrderItem[]

  @@index([isActive, isFeatured, sortOrder])
  @@index([categoryId, sortOrder])
}

model ShopOrder {
  id             String            @id @default(cuid())
  orderNumber    String            @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  addressLine1   String
  addressLine2   String?
  city           String
  province       String?
  postalCode     String?
  notes          String?
  subtotal       Int
  shippingFee    Int               @default(0)
  totalAmount    Int
  status         ShopOrderStatus   @default(PENDING)
  paymentStatus  ShopPaymentStatus @default(PENDING)
  paymentMethod  ShopPaymentMethod @default(COD)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          ShopOrderItem[]

  @@index([customerEmail, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

model ShopOrderItem {
  id          String       @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  sku         String?
  imageUrl    String?
  price       Int
  quantity    Int
  lineTotal   Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  order       ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     ShopProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}
