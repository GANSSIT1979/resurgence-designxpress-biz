enum ShopOrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
enum ShopPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
enum ShopPaymentMethod {
  COD
  GCASH_MANUAL
  MAYA_MANUAL
  BANK_TRANSFER
  CARD_MANUAL
  CASH
}
model ShopCategory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products    ShopProduct[]

  @@index([isActive, sortOrder])
}
model ShopProduct {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  sku                 String?              @unique
  description         String
  shortDescription    String?
  price               Int
  compareAtPrice      Int?
  stock               Int                  @default(0)
  imageUrl            String?
  badgeLabel          String?
  material            String?
  fitNotes            String?
  careInstructions    String?
  availableSizes      String?
  availableColors     String?
  isOfficialMerch     Boolean              @default(true)
  sortOrder           Int                  @default(0)
  isActive            Boolean              @default(true)
  isFeatured          Boolean              @default(false)
  categoryId          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  category            ShopCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems          ShopOrderItem[]
  postProductTags     PostProductTag[]
  sponsoredPlacements SponsoredPlacement[]

  @@index([isActive, isFeatured, sortOrder])
  @@index([isOfficialMerch, isActive, sortOrder])
  @@index([categoryId, sortOrder])
}
model ShopOrder {
  id            String            @id @default(cuid())
  orderNumber   String            @unique
  customerName  String
  customerEmail String
  customerPhone String
  addressLine1  String
  addressLine2  String?
  city          String
  province      String?
  postalCode    String?
  notes         String?
  subtotal      Int
  shippingFee   Int               @default(0)
  totalAmount   Int
  status        ShopOrderStatus   @default(PENDING)
  paymentStatus ShopPaymentStatus @default(PENDING)
  paymentMethod ShopPaymentMethod @default(COD)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         ShopOrderItem[]

  @@index([customerEmail, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}
model ShopOrderItem {
  id           String       @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  sku          String?
  imageUrl     String?
  variantLabel String?
  price        Int
  quantity     Int
  lineTotal    Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  order        ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      ShopProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

