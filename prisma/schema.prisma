  @@index([authorUserId, lastViewedAt])
  @@index([viewerUserId])
  @@index([viewerSessionKey])
  @@index([deviceHash])
  @@index([contentPostId, viewerUserId])
  @@index([contentPostId, viewerSessionKey])
  @@index([contentPostId, deviceHash])
