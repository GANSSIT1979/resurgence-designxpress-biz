{
  "expo": {
    "name": "Resurgence",
    "slug": "resurgence-mobile",
    "scheme": "resurgence",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "biz.resurgence.dx"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "biz.resurgence.dx"
    },
    "extra": {
      "apiUrl": "https://www.resurgence-dx.biz"
    }
  }
}
