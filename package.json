{
  "name": "resurgence-powered-by-designxpress",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prisma:prepare": "node scripts/prepare-prisma-schema.mjs",
    "prisma:generate": "npm run prisma:prepare && prisma generate --schema prisma/schema.generated.prisma",
    "dev": "npm run prisma:prepare && next dev",
    "dev:https": "npm run prisma:prepare && next dev --experimental-https --experimental-https-key certificates/localhost-key.pem --experimental-https-cert certificates/localhost.pem",
    "build": "npm run prisma:generate && node scripts/build-web-only.mjs",
    "vercel-build": "npm run prisma:generate && node scripts/build-web-only.mjs",
    "start": "next start",
    "db:push": "node scripts/push-prisma-schema.mjs",
    "db:seed": "npm run prisma:prepare && tsx prisma/seed.ts",
    "db:migrate": "npm run prisma:prepare && prisma migrate dev --schema prisma/schema.generated.prisma",
    "db:deploy": "npm run prisma:prepare && prisma migrate deploy --schema prisma/schema.generated.prisma",
    "db:migrate:deploy": "npm run prisma:prepare && prisma migrate deploy --schema prisma/schema.generated.prisma",
    "db:validate": "npm run prisma:prepare && prisma validate --schema prisma/schema.generated.prisma",
    "docs:check": "node scripts/check-markdown-links.mjs",
    "docs:production-status": "node scripts/update-production-status.mjs",
    "docs:production-status:check": "node scripts/check-production-status.mjs",
    "local:preflight": "node scripts/local-preflight.mjs",
    "runtime:verify": "node scripts/verify-runtime-routes.mjs",
    "support:verify": "node scripts/verify-support-routes.mjs",
    "phase12:verify": "node scripts/verify-phase-12.mjs",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@openai/agents": "^0.3.9",
    "@openai/chatkit-react": "^0.0.0",
    "@prisma/client": "^6.0.1",
    "@vercel/analytics": "^2.0.1",
    "jose": "^5.9.6",
    "next": "^15.5.15",
    "openai": "^4.0.0",
    "prisma": "^6.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": "20.x"
  },
  "description": "Updated: 2026-04-21",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GANSSIT1979/resurgence-designxpress-biz.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/GANSSIT1979/resurgence-designxpress-biz/issues"
  },
  "homepage": "https://github.com/GANSSIT1979/resurgence-designxpress-biz#readme"
}
