{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "redirects": [
    {
      "source": "/product/:path*",
      "has": [
        {
          "type": "host",
          "value": "shop.resurgence-dx.biz"
        }
      ],
      "destination": "https://www.resurgence-dx.biz/shop/product/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "partnership.resurgence-dx.biz"
        }
      ],
      "destination": "https://www.resurgence-dx.biz/partnerships",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "support.resurgence-dx.biz"
        }
      ],
      "destination": "https://www.resurgence-dx.biz/support",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "shop.resurgence-dx.biz"
        }
      ],
      "destination": "https://www.resurgence-dx.biz/shop",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "partnership.resurgence-dx.biz"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "support.resurgence-dx.biz"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "shop.resurgence-dx.biz"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/invoice-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}