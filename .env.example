### `.env.example`

```dotenv
# Database
PRISMA_DB_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Admin credentials
# Optional emergency fallback admin login when the database is unavailable.
# Seeded users should be stored as password hashes in the database.
ADMIN_EMAIL=acacto@designxpress.biz
ADMIN_PASSWORD_HASH=replace-with-email-password-secret

# Session secret
# Generate a strong random value for real environments.
JWT_SECRET=replace-with-a-long-random-secret

# Public site configuration
COMPANY_NAME=DesignXpress Merchandising OPC
NEXT_PUBLIC_SITE_NAME=Resurgence Powered by DesignXpress
NEXT_PUBLIC_SITE_URL=https://resurgence-dx.biz
# Set true in production to redirect HTTP requests to HTTPS.
FORCE_HTTPS=false
# Optional comma-separated extra hostnames allowed to load Next dev assets.
NEXT_ALLOWED_DEV_ORIGINS=

# Company contact details (public)
NEXT_PUBLIC_CONTACT_NAME=Jake Anilao
NEXT_PUBLIC_CONTACT_ROLE=Sponsorship / Partnerships
NEXT_PUBLIC_CONTACT_EMAIL=customerservice@designxpress.biz
NEXT_PUBLIC_CONTACT_PHONE=+639387841636
NEXT_PUBLIC_SUPPORT_EMAIL=acacto@designxpress.biz
NEXT_PUBLIC_SUPPORT_PHONE=+639957558147
NEXT_PUBLIC_BUSINESS_HOURS=Monday to Saturday, 9:00 AM to 6:00 PM, Asia/Manila
NEXT_PUBLIC_LOCATION=Philippines
NEXT_PUBLIC_CURRENCY=PHP
NEXT_PUBLIC_PAYMENT_METHODS=GCash, Maya, Bank Transfer, Credit/Debit Card, Cash
NEXT_PUBLIC_SHIPPING_AREA=Philippines nationwide
NEXT_PUBLIC_CONTACT_ADDRESS=B2 L1 Coster St., Corner J.P Rizal St., Doña Ana, Camarin, Caloocan, Philippines, 1428

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_WORKFLOW_ID=pmpt_69e33ad844ec8197be2a4766afd194c508d8cafb69b0f67a
OPENAI_WORKFLOW_VERSION=5
OPENAI_WEBHOOK_SECRET=replace-with-openai-webhook-secret
OPENAI_DEFAULT_MODEL=5.4-nano

# Optional email automation webhook
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_SECRET=replace-with-email-webhook-secret

# App runtime
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
PRISMA_HIDE_UPDATE_MESSAGE=1
PORT=3000
