# Safe example file. Do not put real production secrets here.

PRISMA_DB_PROVIDER="postgresql"
DATABASE_URL="postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

NEXT_PUBLIC_SITE_URL="https://www.resurgence-dx.biz"
NEXT_PUBLIC_SITE_NAME="Resurgence Powered by DesignXpress"
COMPANY_NAME="DesignXpress Merchandising OPC"
FORCE_HTTPS="true"

JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
ADMIN_EMAIL="admin@resurgence-dx.biz"
ADMIN_PASSWORD_HASH="REPLACE_WITH_HASHED_PASSWORD"

OPENAI_API_KEY="REPLACE_WITH_OPENAI_API_KEY"
OPENAI_WEBHOOK_SECRET="REPLACE_WITH_OPENAI_WEBHOOK_SECRET"
OPENAI_WORKFLOW_ID="REPLACE_WITH_OPENAI_WORKFLOW_ID"
OPENAI_WORKFLOW_VERSION="REPLACE_WITH_OPENAI_WORKFLOW_VERSION"

NEXT_TELEMETRY_DISABLED="1"
PRISMA_HIDE_UPDATE_MESSAGE="1"

UPLOAD_STORAGE="local"

# Optional Supabase public values
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE_WITH_SUPABASE_ANON_KEY"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="REPLACE_WITH_SUPABASE_PUBLISHABLE_KEY"

# Optional Supabase private values
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="REPLACE_WITH_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_JWT_SECRET="REPLACE_WITH_SUPABASE_JWT_SECRET"

# Optional Cloudflare R2
R2_ACCOUNT_ID="REPLACE_WITH_R2_ACCOUNT_ID"
R2_ACCESS_KEY_ID="REPLACE_WITH_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="REPLACE_WITH_R2_SECRET_ACCESS_KEY"
R2_BUCKET="resurgence-merch"
R2_PUBLIC_BASE_URL="https://example.r2.cloudflarestorage.com"
